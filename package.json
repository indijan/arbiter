{
  "name": "arbiter",
  "private": true,
  "packageManager": "pnpm@10.28.2",
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "dev": "pnpm -C apps/web dev",
    "build": "pnpm -C apps/web build",
    "lint": "pnpm -C apps/web lint",
    "runner": "pnpm -C apps/runner start",
    "runner:once": "pnpm -C apps/runner once",
    "ops:reload": "zsh scripts/ops-reload-local.sh"
  }
}
